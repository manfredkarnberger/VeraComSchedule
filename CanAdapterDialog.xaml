<Window x:Class="VeraCom.CanAdapterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CAN Adapter auswählen"
        Height="200"
        Width="300"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox x:Name="AdapterList" Grid.Row="0"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="70" Margin="5" Click="Ok_Click"/>
            <Button Content="Abbrechen" Width="70" Margin="5" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
    